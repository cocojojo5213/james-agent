# james-agent environment variables for docker-compose
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# === Provider API Key (pick ONE) ===

# Option 1: Generic key (set JAMES_PROVIDER to choose type)
JAMES_API_KEY=

# Option 2: Third-party provider (auto-detects type + baseUrl)
# Just uncomment and fill ONE of these:
#DEEPSEEK_API_KEY=sk-xxx
#GROQ_API_KEY=gsk_xxx
#XAI_API_KEY=xai-xxx
#MISTRAL_API_KEY=
#TOGETHER_API_KEY=
#MOONSHOT_API_KEY=
#SILICONFLOW_API_KEY=
#OPENROUTER_API_KEY=

# Option 3: Official providers
#ANTHROPIC_API_KEY=sk-ant-xxx
#OPENAI_API_KEY=sk-xxx

# === Optional overrides ===
#JAMES_PROVIDER=deepseek
#JAMES_MODEL=deepseek-chat
#JAMES_BASE_URL=

# === Telegram ===
JAMES_TELEGRAM_TOKEN=

# === Feishu (optional) ===
JAMES_FEISHU_APP_ID=
JAMES_FEISHU_APP_SECRET=

# === WeCom (optional) ===
JAMES_WECOM_TOKEN=
JAMES_WECOM_ENCODING_AES_KEY=
JAMES_WECOM_RECEIVE_ID=
