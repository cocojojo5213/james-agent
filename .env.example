# james-agent environment variables for docker-compose
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: AI provider API key
JAMES_API_KEY=sk-ant-...

# Optional: Telegram bot token
JAMES_TELEGRAM_TOKEN=

# Optional: Feishu bot credentials
JAMES_FEISHU_APP_ID=
JAMES_FEISHU_APP_SECRET=

# Optional: WeCom intelligent bot credentials
JAMES_WECOM_TOKEN=
JAMES_WECOM_ENCODING_AES_KEY=
JAMES_WECOM_RECEIVE_ID=
